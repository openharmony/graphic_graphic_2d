import("//build/test.gni")
import("//foundation/graphic/graphic_2d/graphic_config.gni")

module_output_path = "graphic_2d/graphic_2d/rosen/modules/render_service_base"

ohos_unittest("RSProxyTest") {
  module_out_path = module_output_path

  sources = [ "rs_client_to_service_connect_hub_test.cpp",
   "rs_render_service_client_proxy_test.cpp"]

  defines = [ "ENABLE_RS_PROXY" ]

  configs = [ ":rs_proxy_test_config" ]

  deps = [
    "$graphic_2d_root/rosen/modules/render_service_base/proxy:render_service_proxy_src",
  ]

  external_deps = [
    "graphic_surface:surface_headers",
    "hilog:libhilog",
    "ipc:ipc_core",
  ]

  subsystem_name = "graphic"
}

config("rs_proxy_test_config") {
  visibility = [ ":*" ]
  include_dirs = [
    "$graphic_2d_root/utils/log",
  ]

  cflags = [
    "-Wall",
    "-Werror",
    "-g3",
    "-Dprivate=public",
    "-Dprotected=public",
  ]
}

group("unittest") {
  testonly = true
  deps = [ ":RSProxyTest" ]
}
