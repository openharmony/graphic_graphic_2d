import("//build/config/features.gni")
import("//build/test.gni")
import("//foundation/graphic/graphic_2d/graphic_config.gni")
module_output_path = "graphic_2d/graphic_2d"

ohos_fuzztest("RSGpuDirtyRegionCollectionFuzzTest") {
  fuzz_config_file = "$graphic_2d_root/rosen/modules/render_service_base/test/fuzztest/rs_gpu_dirty_region_collection_fuzzer"
  module_out_path = module_output_path

  include_dirs =
      [ "$graphic_2d_root/rosen/modules/render_service_base/include" ]
  cflags = [
    "-g",
    "-O0",
    "-Wno-unused-variable",
    "-fno-omit-frame-pointer",
    "-Dprivate=public",
    "-Dprotected=public",
  ]
  sources = [ "rs_gpu_dirty_region_collection_fuzzer.cpp" ]
  deps = [
    "$graphic_2d_root/rosen/modules/render_service_base:librender_service_base",
  ]

  external_deps = [
    "c_utils:utils",
    "hilog:libhilog",
  ]
}

group("fuzztest") {
  testonly = true
  deps = []
  deps += [
    ":RSGpuDirtyRegionCollectionFuzzTest",
  ]
}