import("//build/ohos.gni")
import("//foundation/graphic/graphic_2d/graphic_config.gni")
import("$graphic_2d_root/rosen/modules/render_service_base/config.gni")
 
## Build libvsync_manager
ohos_source_set("libvsync_manager") {
