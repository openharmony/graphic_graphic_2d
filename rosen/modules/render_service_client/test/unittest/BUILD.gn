import("//build/test.gni")
import("//foundation/graphic/graphic_2d/graphic_config.gni")
import("$rosen_root/modules/render_service_base/config.gni")

module_out_path = "graphic_2d/graphic_2d/render_service_client"

group("unittest") {
  testonly = true

  deps = [
    ":RSDisplayModeTest",
    ":RSDropframeTest",
    ":RSEventTest",
    ":RSInterfacesTest",
    ":RSJankDetectorTest",
    ":RSRegionTest",
    ":RSScreenSkipFrameTest",
    ":RSTransactionsTest",
    ":RSTunnelHandleTest",
    ":RSVirtualScreenRefreshRateTest",
    "animation:RSAnimationTest",
    "animation:RSAnimationTest1",
    "animation:RSAnimationTest2",
    "animation:RSAnimationTest3",
    "animation:RSAnimationTest4",
    "animation:RSAnimationTest5",
    "ui_effect:unittest",
  ]

  if (rosen_is_ohos && graphic_2d_feature_enable_vulkan && graphic_2d_feature_rs_modifiers_draw_enable) {
    deps += [
      ":RSCanvasModifiersDrawAgentTest",
      ":RSCanvasModifiersDrawTest",
      ":RSModifiersDrawTest",
      ":RSModifiersDrawThreadTest",
    ]
  }
}

## Build RSCanvasModifiersDrawTest
ohos_unittest("RSCanvasModifiersDrawTest") {
  module_out_path = module_out_path
  sources = [ "modifier_render_thread/rs_canvas_modifiers_draw_test.cpp" ]
  include_dirs = [ "$graphic_2d_root/rosen/modules/render_service_base/src" ]
  deps = [ ":rs_client_test_common" ]
  external_deps = [
    "hilog:libhilog",
  ]
}
 
