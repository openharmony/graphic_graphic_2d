import("//foundation/graphic/graphic_2d/graphic_config.gni")

group("test") {
  testonly = true
  deps = [
    "render_service/fuzztest/composer/composer_service/layer_backend:fuzztest",
    "render_service/systemtest/composer/composer_service/layer_backend:systemtest",
    "render_service/systemtest/pipeline:systemtest",
    "render_service/unittest/composer/composer_service/layer_backend:unittest",
    "render_service/unittest/composer/composer_service/pipeline:unittest",
  ]

  if (graphic_2d_modifier_ng_enable) {
    deps += []
  }

  if (graphic_2d_feature_enable_vulkan) {
    deps += []
  }

  if (graphic_2d_feature_enable_rspipeline) {
    deps += [ "render_service/unittest/drawable:unittest" ]
  }

  if (graphic_2d_feature_rs_enable_profiler) {
    deps += [ "render_service_profiler/unittest:unittest" ]
  }

  if (defined(graphic_2d_feature_subtree_parallel_enable) &&
      graphic_2d_feature_subtree_parallel_enable &&
      defined(graphic_2d_subtree_configs.subtree_root)) {
    deps += [ "render_service/unittest/subtree:unittest" ]
  }
}
