import("//build/test.gni")
import("//foundation/graphic/graphic_2d/graphic_config.gni")

module_output_path = "graphic_2d/graphic_2d/rosen_engine/render_service/dfx"

group("unittest") {
  testonly = true

  deps = [
    ":RSPipelineDumperTest",
    ":RSPipelineDumpManagerTest",
  ]
}

###############################################################################
config("dfx_test") {
  include_dirs = [ "$graphic_2d_root/rosen/modules/render_service/core" ]
}

