import("//build/test.gni")
import("//foundation/graphic/graphic_2d/graphic_config.gni")

ohos_unittest("graphic_2d_frame_report_test") {
  module_out_path = "graphic_2d/graphic_2d/rosen/modules/frame_report"
  include_dirs = [ "$graphic_2d_root/rosen/modules/frame_report/include" ]
  sources = [ "rs_frame_report_test.cpp" ]

  deps = [ "$graphic_2d_root/utils/test_header:test_header" ]
  external_deps = [
    "hilog:libhilog",
    "vulkan-headers:vulkan_headers",
    "vulkan-loader:vulkan_loader",
    "googletest:gmock_main",
  ]

  if (current_os == "ohos") {
    sources += [ "$graphic_2d_root/rosen/modules/frame_report/src/rs_frame_report.cpp" ]
    external_deps += [ "frame_aware_sched:frame_ui_intf"]
  } else if (!is_arkui_x) {
    sources += [ "$graphic_2d_root/rosen/modules/frame_report/src/mingw/rs_frame_report.cpp" ]
  }

  cflags = [
    "-Wall",
    "-Werror",
    "-g3",
    "-Dprivate=public",
    "-Dprotected=public",
    "-DTEST_ENABLED",
  ]

  defines = []
  if (graphic_2d_feature_enable_vulkan) {
    defines += [
      "RS_ENABLE_VK",
    ]
  }

  part_name = "graphic_2d"
  subsystem_name = "graphic"
}

group("unittest") {
  testonly = true

  deps = [ ":graphic_2d_frame_report_test" ]
}
