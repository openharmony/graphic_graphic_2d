import("//build/test.gni")
import("//foundation/graphic/graphic_2d/frameworks/text/config.gni")
import("//foundation/graphic/graphic_2d/graphic_config.gni")

text_unittest("text_effect_test") {
  include_dirs = [
    "$rosen_text_root/adapter/skia",
    "$rosen_text_root/service/text_effect",
    "$rosen_root/modules/2d_graphics/include",
    "$rosen_root/modules/2d_graphics/src",
    "$rosen_root/modules/2d_graphics/src/drawing/engine_adapter",
    "$rosen_root/modules/render_service_base/include",
    "$rosen_text_root/adapter/skia/impl",
    "$rosen_text_root/service",
  ]

  sources = [
    "text_effect_factory_creator_test.cpp",
    "text_flip_effect_test.cpp",
  ]

  deps = [ "$rosen_root/modules/2d_graphics:2d_graphics" ]

  external_deps = [
    "bounds_checking_function:libsec_shared",
    "googletest:gmock",
    "hilog:libhilog",
    "image_framework:image_native",
    "ipc:ipc_single",
  ]
}

group("unittest") {
  testonly = true

  deps = [ ":text_effect_test" ]
}
