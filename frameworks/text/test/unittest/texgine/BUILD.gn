import("//build/test.gni")
import("//foundation/graphic/graphic_2d/frameworks/text/config.gni")
import("//foundation/graphic/graphic_2d/graphic_config.gni")

text_unittest("texgine_test") {
  sources = [
    "font_config_test.cpp",
    "font_descriptor_cache_test.cpp",
    "font_parser_test.cpp",
  ]

  include_dirs = [
    "$rosen_root/modules/2d_graphics/include",
    "$rosen_root/modules/2d_graphics/src/drawing/engine_adapter",
    "$rosen_text_root/service/texgine/src",
    "$rosen_text_root/service/texgine/src/opentype_parser",
  ]

  deps = [ "$rosen_root/modules/2d_graphics:2d_graphics" ]

  external_deps = [
    "c_utils:utils",
    "i18n:intl_util",
  ]
}

group("unittest") {
  testonly = true
  deps = [ ":texgine_test" ]
}
